# ============================================================
# HomeCostGuide Environment Variables
# Copy this to .env.local and fill in your values
# ============================================================

# --- SUPABASE ---
# Get from: https://supabase.com/dashboard > Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_KEY=your-service-role-key-here

# --- OUTSCRAPER (for contractor data scraping) ---
# Get from: https://outscraper.com > Dashboard > API
OUTSCRAPER_API_KEY=your-outscraper-api-key-here

# --- INDEXNOW (for fast Bing indexing) ---
# Generate: https://www.uuidgenerator.net/
INDEXNOW_KEY=your-uuid-key-here

# --- SITE CONFIG ---
SITE_URL=https://www.homecostguide.com
